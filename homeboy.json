{
  "auto_cleanup": false,
  "extensions": {
    "wordpress": {}
  },
  "id": "data-machine-socials",
  "remote_path": "",
  "version_targets": [
    {
      "file": "data-machine-socials.php",
      "pattern": "Version:\\s*([0-9.]+)"
    },
    {
      "file": "data-machine-socials.php",
      "pattern": "DATAMACHINE_SOCIALS_VERSION',\\s*'([0-9.]+)'"
    }
  ],
  "audit_rules": {
    "layer_rules": [
      {
        "name": "cli-uses-ability-registry",
        "forbid": {
          "glob": "inc/Cli/**/*.php",
          "patterns": [
            "new \\DataMachineSocials\\Abilities\\"
          ]
        }
      },
      {
        "name": "rest-uses-ability-registry",
        "forbid": {
          "glob": "inc/RestApi.php",
          "patterns": [
            "new \\DataMachineSocials\\Abilities\\"
          ]
        }
      },
      {
        "name": "chat-tools-use-ability-registry",
        "forbid": {
          "glob": "inc/Chat/**/*.php",
          "patterns": [
            "new \\DataMachineSocials\\Abilities\\"
          ]
        }
      }
    ]
  }
}